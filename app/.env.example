# Base-layer RPC — use a real provider; public devnet 429s on getProgramAccounts.
VITE_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Read-only ER identity to mint a PER/TEE auth token (never signs, needs no SOL).
# Generate: node -e "const{Keypair}=require('@solana/web3.js');console.log(JSON.stringify(Array.from(Keypair.generate().secretKey)))"
VITE_ER_READER_SECRET=[...secretKey as JSON array...]
