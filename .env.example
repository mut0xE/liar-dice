# ── Base-layer RPC ──────────────────────────────────────────────
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Ephemeral Rollup / TEE endpoint ─────────────────────────────
ROUTER_ENDPOINT=https://devnet-router.magicblock.app/

# Overrides the resolved router endpoint with a fixed ER/TEE fqdn.
EPHEMERAL_PROVIDER_ENDPOINT=

# ── Test player wallets (auto-generated + auto-funded on first test run) ─
# Optional: set these to reuse specific devnet wallets across runs instead of
# generating fresh ones every time. If unset, tests/helpers/accounts.ts's
# keypairFromEnvOrGenerate() creates one, appends it here, and fundKeypair()
# tops it up from your Anchor wallet (~/.config/solana/id.json).
HOST_KEY=
PLAYER_B_KEY=

# ── Test session keys (auto-generated on first test run) ────────
HOST_SESSION_KEY=
PLAYER_B_SESSION_KEY=
